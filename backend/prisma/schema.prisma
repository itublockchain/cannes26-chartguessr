generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  walletAddress String    @unique
  dynamicUserId String?   @unique
  username      String?
  characterId   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  matchesAsP1   Match[]   @relation("Player1")
  matchesAsP2   Match[]   @relation("Player2")
  drawings      Drawing[]
}

model Character {
  id       String @id @default(uuid())
  name     String
  slug     String @unique
  imageUrl String
}

model Match {
  id             String     @id @default(uuid())
  onchainMatchId String     @unique
  player1Id      String
  player2Id      String
  player1        User       @relation("Player1", fields: [player1Id], references: [id])
  player2        User       @relation("Player2", fields: [player2Id], references: [id])
  entryFee       Decimal
  state          MatchState @default(CREATED)
  winnerId       String?
  startPrice     Decimal?
  endPrice       Decimal?
  priceBuffer    Json?
  createdAt      DateTime   @default(now())
  lockedAt       DateTime?
  resolvedAt     DateTime?
  drawings       Drawing[]
}

enum MatchState {
  CREATED
  AWAITING_PLAYERS
  PARTIAL
  LOCKED
  PLAYING
  CALCULATING
  RESOLVED
  CANCELLED
  DRAW
}

model Drawing {
  id          String   @id @default(uuid())
  matchId     String
  match       Match    @relation(fields: [matchId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  pathData    Json
  score       Float?
  submittedAt DateTime @default(now())
}
